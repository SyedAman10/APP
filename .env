
# LMN8 App Environment Variables
# Copy this file to .env and fill in your actual values

# AI API Configuration
EXPO_PUBLIC_AI_API_KEY=your_openai_api_key_here
EXPO_PUBLIC_AI_API_URL=https://api.openai.com/v1
EXPO_PUBLIC_AI_MODEL=gpt-4o-mini

# Backend API Configuration


# Development/Testing URLs (uncomment to use)
EXPO_PUBLIC_API_BASE_URL=https://lumen8health.com
EXPO_PUBLIC_BACKEND_URL=https://lumenatehealth.com