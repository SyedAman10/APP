{
  "cli": {
    "version": ">= 13.2.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://lumen8health.com",
        "EXPO_PUBLIC_BACKEND_URL": "https://lumen8health.com",
        "EXPO_PUBLIC_PERSONA_API_URL": "https://luminate.snifr.app"
      }
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://lumen8health.com",
        "EXPO_PUBLIC_BACKEND_URL": "https://lumen8health.com",
        "EXPO_PUBLIC_PERSONA_API_URL": "https://luminate.snifr.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

